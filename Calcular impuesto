      "source": [
        "def calcular_impuesto(salario):\n",
        "  def calcular_seguridad_social(monto):\n",
        "    return monto * 0.07\n",
        "\n",
        "  def calcular_irpf(monto):\n",
        "    return monto * 0.15\n",
        "\n",
        "  ss = calcular_seguridad_social(salario)\n",
        "  irpf = calcular_irpf(salario)\n",
        "  return salario - ss - irpf\n",
        "\n",
        "print(calcular_impuesto(1000))"
